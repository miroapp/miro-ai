{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "codex-plugin.schema.json",
  "title": "Codex Plugin Manifest",
  "description": "Schema for validating Codex plugin manifests in .codex-plugin/plugin.json",
  "type": "object",
  "required": ["name", "version", "description", "author", "interface"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 5
    },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string" },
        "url": { "type": "string" }
      },
      "additionalProperties": true
    },
    "homepage": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skills": {
      "type": "string",
      "pattern": "^\\./"
    },
    "hooks": {
      "type": "string",
      "pattern": "^\\./"
    },
    "mcpServers": {
      "type": "string",
      "pattern": "^\\./"
    },
    "apps": {
      "type": "string",
      "pattern": "^\\./"
    },
    "interface": {
      "type": "object",
      "required": [
        "displayName",
        "shortDescription",
        "longDescription",
        "developerName",
        "category",
        "capabilities",
        "websiteURL",
        "privacyPolicyURL",
        "termsOfServiceURL",
        "defaultPrompt"
      ],
      "properties": {
        "displayName": { "type": "string", "minLength": 1 },
        "shortDescription": { "type": "string", "minLength": 5 },
        "longDescription": { "type": "string", "minLength": 5 },
        "developerName": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "websiteURL": { "type": "string", "minLength": 1 },
        "privacyPolicyURL": { "type": "string", "minLength": 1 },
        "termsOfServiceURL": { "type": "string", "minLength": 1 },
        "defaultPrompt": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        },
        "brandColor": { "type": "string" },
        "composerIcon": {
          "type": "string",
          "pattern": "^\\./"
        },
        "logo": {
          "type": "string",
          "pattern": "^\\./"
        },
        "screenshots": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\./"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
