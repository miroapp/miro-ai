{
  "name": "miro-ai",
  "version": "1.0.0",
  "type": "module",
  "description": "Miro AI Developer Tools - plugins for Claude Code, Gemini CLI, Cursor, and Kiro",
  "scripts": {
    "validate": "bun validation/src/index.ts",
    "validate:frontmatter": "bun validation/src/index.ts --frontmatter-only",
    "validate:bash": "bun validation/src/index.ts --bash-only",
    "validate:consistency": "bun validation/src/index.ts --consistency-only",
    "validate:version": "bun validation/src/index.ts --version-only",
    "convert": "bun validation/src/converters/index.ts",
    "package:copilot-cowork": "bun validation/src/package-copilot-cowork.ts",
    "sync:cursor": "bun validation/src/converters/index.ts --cursor && bun validation/src/sync-cursor.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "ajv": "^8.17.1",
    "execa": "^9.5.1",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7"
  },
  "author": {
    "name": "Miro",
    "email": "support@miro.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/miroapp/miro-ai"
  }
}
